#!/bin/sh
# POST ?name=<file> -> enable/disable by toggling the .disabled suffix.
# enabled  foo.sh           -> foo.sh.disabled
# disabled foo.sh.disabled  -> foo.sh
. /www/cgi-bin/lib.sh

path="$(script_path "$(query_get name)")" || {
  send_json "400 Bad Request"; printf '{"ok":false,"output":"bad script name"}'; exit 0; }

[ -f "$path" ] || { send_json "404 Not Found"; printf '{"ok":false,"output":"not found"}'; exit 0; }

case "$path" in
  *.sh.disabled) new="${path%.disabled}"; enabled=true  ;;
  *.sh)          new="${path}.disabled";  enabled=false ;;
esac

mv -f "$path" "$new"
send_json "200 OK"
printf '{"ok":true,"enabled":%s,"file":"%s"}' "$enabled" "$(basename "$new" | json_escape)"
