#!/bin/sh
# POST raw YAML body -> validate with `mihomo -t` without applying.
# Candidate lives in tmpfs (/dev/shm) — никаких записей на флеш при проверке.
# Returns: { "ok": bool, "output": "..." }
. /www/cgi-bin/lib.sh

TMPDIR_="/dev/shm"; { [ -d "$TMPDIR_" ] && [ -w "$TMPDIR_" ]; } || TMPDIR_="/tmp"
CAND="$TMPDIR_/.cfg-check.$$"
read_body > "$CAND"
trap 'rm -f "$CAND"' EXIT

if [ ! -s "$CAND" ]; then
  send_json "400 Bad Request"
  printf '{"ok":false,"output":"empty request body"}'
  exit 0
fi

# -t tests the config; -d keeps relative provider paths resolving against MIHOMO_DIR
OUT="$(SAFE_PATHS="$TMPDIR_" mihomo -t -d "$MIHOMO_DIR" -f "$CAND" 2>&1)"
RC=$?

ESC="$(printf '%s' "$OUT" | json_escape)"
send_json "200 OK"
if [ "$RC" -eq 0 ]; then
  printf '{"ok":true,"output":"%s"}' "$ESC"
else
  printf '{"ok":false,"output":"%s"}' "$ESC"
fi
