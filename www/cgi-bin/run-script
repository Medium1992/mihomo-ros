#!/bin/sh
# POST ?name=<file> -> run the script now (cwd = MIHOMO_DIR), capture output.
# Scripts otherwise run only at container start; this lets you trigger one live.
. /www/cgi-bin/lib.sh

path="$(script_path "$(query_get name)")" || {
  send_json "400 Bad Request"; printf '{"ok":false,"output":"bad script name"}'; exit 0; }

[ -f "$path" ] || { send_json "404 Not Found"; printf '{"ok":false,"output":"not found"}'; exit 0; }

OUT="$(cd "$MIHOMO_DIR" && /bin/sh "$path" 2>&1)"
RC=$?
ESC="$(printf '%s' "$OUT" | json_escape)"

send_json "200 OK"
if [ "$RC" -eq 0 ]; then
  printf '{"ok":true,"output":"%s"}'  "${ESC:-(no output)}"
else
  printf '{"ok":false,"output":"exit %s\\n%s"}' "$RC" "$ESC"
fi
