#!/bin/sh
# POST raw YAML body -> validate (in tmpfs), save, hot-reload mihomo via API.
# Проверка идёт в /dev/shm (без износа флеша); на флеш пишется только итоговый
# config.yaml — атомарно (temp в той же ФС + rename).
# Returns: { "ok": bool, "stage": "validate|apply", "output": "..." }
. /www/cgi-bin/lib.sh

TMPDIR_="/dev/shm"; { [ -d "$TMPDIR_" ] && [ -w "$TMPDIR_" ]; } || TMPDIR_="/tmp"
CAND="$TMPDIR_/.cfg-save.$$"
read_body > "$CAND"
trap 'rm -f "$CAND"' EXIT

if [ ! -s "$CAND" ]; then
  send_json "400 Bad Request"
  printf '{"ok":false,"stage":"validate","output":"empty request body"}'
  exit 0
fi

# 1) validate (tmpfs candidate)
OUT="$(SAFE_PATHS="$TMPDIR_" mihomo -t -d "$MIHOMO_DIR" -f "$CAND" 2>&1)"
if [ $? -ne 0 ]; then
  ESC="$(printf '%s' "$OUT" | json_escape)"
  send_json "200 OK"
  printf '{"ok":false,"stage":"validate","output":"%s"}' "$ESC"
  exit 0
fi

# запоминаем старые external-controller/secret ДО подмены конфига
OLD_EC="$(_yaml external-controller)"
OLD_SEC="$(_yaml secret)"

# 2) commit: backup + atomic replace on the same filesystem
[ -f "$CONFIG" ] && cp "$CONFIG" "$MIHOMO_DIR/.config.bak"
NEW="$MIHOMO_DIR/.config.new"
cp "$CAND" "$NEW" && mv -f "$NEW" "$CONFIG"

# 2.5) external-controller/secret НЕ применяются на горячую (RESTful-сервер
#      ядра поднимается один раз при старте процесса). Если они изменились —
#      перезапускаем mihomo: kill -> супервизор поднимет его с новым конфигом
#      (на новом порту/секрете). Иначе панель ушла бы на новый порт, а ядро
#      осталось бы на старом → «ядро недоступно».
NEW_EC="$(_yaml external-controller)"
NEW_SEC="$(_yaml secret)"
if [ "$OLD_EC" != "$NEW_EC" ] || [ "$OLD_SEC" != "$NEW_SEC" ]; then
  kill -9 $(pidof mihomo) 2>/dev/null || true
  send_json "200 OK"
  printf '{"ok":true,"stage":"restart","output":"Конфиг сохранён. Изменены external-controller/secret — ядро перезапускается (несколько секунд)."}'
  exit 0
fi

# 3) hot-reload via RESTful API (API_SECRET прочитан при source — секрет
#    ещё работающего ядра, поэтому 401 не будет).
#    force выбирается вебкой (?force=true|false):
#      false — МЯГКО: обновляет proxies/groups/rules/dns, входящие
#              листенеры/порты/TUN НЕ пересоздаются (сокеты клиентов живут);
#      true  — ПОЛНОСТЬЮ: пересоздаёт и листенеры/порты/TUN (нужно при смене
#              mixed-port/allow-lan/bind-address/tun/listeners), рвёт соединения.
FORCE="$(query_get force)"; [ "$FORCE" = "true" ] || FORCE="false"
APIOUT="$(api PUT "/configs?force=$FORCE" "{\"path\":\"$CONFIG\"}" 2>&1)"
if [ $? -ne 0 ]; then
  ESC="$(printf 'saved, but reload failed:\n%s' "$APIOUT" | json_escape)"
  send_json "200 OK"
  printf '{"ok":false,"stage":"apply","output":"%s"}' "$ESC"
  exit 0
fi

send_json "200 OK"
printf '{"ok":true,"stage":"apply","output":"config saved and applied"}'
