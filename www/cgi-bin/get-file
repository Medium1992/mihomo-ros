#!/bin/sh
# GET ?dir=<key>&name=<file> -> plain text content
. /www/cgi-bin/lib.sh

path="$(res_path "$(query_get dir)" "$(query_get name)")" || {
  send_text "400 Bad Request"; echo "# bad request"; exit 0; }

if [ -f "$path" ]; then
  send_text "200 OK"
  cat "$path"
else
  send_text "404 Not Found"
  echo "# not found"
fi
