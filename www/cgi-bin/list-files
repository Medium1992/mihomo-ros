#!/bin/sh
# GET ?dir=<key> -> JSON array of files in that resource dir:
# [{ "file":"a.sh", "name":"a.sh", "enabled":true, "size":123 }, ...]
. /www/cgi-bin/lib.sh

dir="$(query_get dir)"
d="$(res_dir "$dir")" || { send_json "400 Bad Request"; printf '[]'; exit 0; }

send_json "200 OK"
printf '['
first=1
for f in "$d"/*; do
  [ -f "$f" ] || continue
  bn="$(basename "$f")"
  res_ext_ok "$dir" "$bn" || continue
  case "$bn" in
    *.disabled) enabled=false; disp="${bn%.disabled}" ;;
    *)          enabled=true;  disp="$bn" ;;
  esac
  sz="$(wc -c < "$f" 2>/dev/null | tr -d ' ')"
  [ "$first" -eq 1 ] || printf ','
  first=0
  printf '{"file":"%s","name":"%s","enabled":%s,"size":%s}' \
    "$(printf '%s' "$bn"   | json_escape)" \
    "$(printf '%s' "$disp" | json_escape)" \
    "$enabled" "${sz:-0}"
done
printf ']'
