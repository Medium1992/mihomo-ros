#!/bin/sh
# GET ?name=<file> -> plain text content of a script
. /www/cgi-bin/lib.sh

path="$(script_path "$(query_get name)")" || {
  send_text "400 Bad Request"; echo "# bad script name"; exit 0; }

if [ -f "$path" ]; then
  send_text "200 OK"
  cat "$path"
else
  send_text "404 Not Found"
  echo "# not found"
fi
