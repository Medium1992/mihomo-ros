#!/bin/sh
# POST raw sh body -> syntax check with `sh -n` (no execution, nothing saved).
# Same interpreter the hooks run with at start, so the check matches reality.
# Returns: { "ok": bool, "output": "..." }
. /www/cgi-bin/lib.sh

# temp candidate in RAM (tmpfs) to avoid flash wear; fall back to /tmp
TMPDIR_="/dev/shm"; { [ -d "$TMPDIR_" ] && [ -w "$TMPDIR_" ]; } || TMPDIR_="/tmp"
CAND="$TMPDIR_/.script-check.$$"
read_body > "$CAND"

if [ ! -s "$CAND" ]; then
  rm -f "$CAND"
  send_json "400 Bad Request"
  printf '{"ok":false,"output":"empty script"}'
  exit 0
fi

OUT="$(sh -n "$CAND" 2>&1)"
RC=$?
rm -f "$CAND"

ESC="$(printf '%s' "$OUT" | json_escape)"
send_json "200 OK"
if [ "$RC" -eq 0 ]; then
  printf '{"ok":true,"output":"%s"}'  "${ESC:-Синтаксис OK ✓}"
else
  printf '{"ok":false,"output":"%s"}' "$ESC"
fi
